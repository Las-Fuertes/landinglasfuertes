# Google Analytics ID
NEXT_PUBLIC_GA_ID=G-9ZXP5ZNDT1

# Environment
NODE_ENV=development

# API endpoints (if needed in the future)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# --- Sección "Súmate" ---
# Bold (donación única). Llave de identidad, segura para el frontend.
# Se obtiene en el panel de Bold: Integraciones > Llaves de integración.
NEXT_PUBLIC_BOLD_API_KEY=
# Llave secreta de Bold. SOLO servidor: nunca prefijarla con NEXT_PUBLIC.
BOLD_SECRET_KEY=
# Enlace público del plan de suscripción de Mercado Pago.
# Al crear el plan en el panel de MP, configurar como URL de retorno:
# https://<dominio>/gracias?origen=suscripcion
NEXT_PUBLIC_MP_SUBSCRIPTION_URL=
# Número de WhatsApp de la fundación con indicativo, sin + (ej. 573001234567).
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Usuario de Instagram (con o sin @).
NEXT_PUBLIC_INSTAGRAM_HANDLE=
